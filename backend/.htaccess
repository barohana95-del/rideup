# =====================================================================
# RideUp — Apache config (Hostinger Shared)
# =====================================================================

# UTF-8
AddDefaultCharset UTF-8

# הסתרת קבצים רגישים
<FilesMatch "^\.(env|gitignore|htaccess)|composer\.(json|lock)$">
    Require all denied
</FilesMatch>

# חסום גישה ישירה לתיקיות lib/ ו-migrations/
RedirectMatch 404 ^/lib/.*$
RedirectMatch 404 ^/migrations/.*$

# החזרת JSON שגיאה לדפי שגיאה במקום HTML
ErrorDocument 404 /api/_404.php
ErrorDocument 500 /api/_500.php

# Pretty URLs ל-API (אופציונלי — נשתמש בהמשך):
# RewriteEngine On
# RewriteRule ^api/public/config$  api/public/config.php   [L]
# וכו'.

# Caching ל-static (אם נגיש frontend מאותו host)
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
</IfModule>
