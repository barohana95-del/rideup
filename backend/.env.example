# =====================================================================
# RideUp Backend — Environment Variables (template)
# העתק לקובץ .env (לא יועלה ל-Git) ומלא את הערכים האמיתיים.
# =====================================================================

# Database (Hostinger MySQL credentials)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=rideup_dev
DB_USER=rideup_dev
DB_PASS=

# Domain config
# בייצור: rideup.co.il. בפיתוח: dev.rideup.co.il, או localhost.
BASE_DOMAIN=dev.rideup.co.il

# CORS — דומיינים מותרים לקריאה מ-frontend.
# מופרדים בפסיק. כולל את ה-dev local של Vite.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Debug mode — בפיתוח 1, בפרודקשן 0.
APP_DEBUG=1

# JWT secret (יווצר אחרי שלב 2)
JWT_SECRET=

# Google OAuth (יווצר אחרי שלב 2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Brevo (יווצר אחרי שלב 2)
BREVO_API_KEY=

# Payments (יווצר אחרי שלב 7)
PAYPLUS_API_KEY=
PAYPLUS_SECRET_KEY=
