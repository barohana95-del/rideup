# =====================================================================
# RideUp Backend — Environment Variables (template)
# Copy to `.env` (gitignored) on Hostinger, fill in real values.
# =====================================================================

# Database (Hostinger MySQL credentials)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=rideup_dev
DB_USER=rideup_dev
DB_PASS=

# Domain config
BASE_DOMAIN=rideup.integrity-web.com

# CORS — comma-separated origins allowed to call the API.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Debug mode — 1 in dev, 0 in production.
APP_DEBUG=1

# Environment — when set to "production", mock auth (X-Mock-User-Id
# header) is rejected. Defaults to dev.
APP_ENV=dev

# ── REQUIRED for Google OAuth ────────────────────────────────────────
# Generate with: php -r "echo bin2hex(random_bytes(32));"
# OR any 64+ character random string.
JWT_SECRET=

# Google OAuth Client ID (Web application). Public — same as VITE one.
GOOGLE_CLIENT_ID=

# Optional — only needed if you ever do server-side OAuth. Not needed
# for our Identity Services (ID token) flow.
GOOGLE_CLIENT_SECRET=

# ── Email (after Stage 3) ────────────────────────────────────────────
BREVO_API_KEY=
EMAIL_FROM=noreply@rideup.co.il
EMAIL_FROM_NAME=RideUp

# ── Payments (after Stage 7) ─────────────────────────────────────────
PAYPLUS_API_KEY=
PAYPLUS_SECRET_KEY=
