# =====================================================================
# RideUp Frontend — Environment Variables (template)
# העתק לקובץ .env.local (לא יועלה ל-Git).
# =====================================================================

# כתובת ה-API. בפיתוח: ה-backend על Hostinger dev subdomain.
VITE_API_URL=https://dev.rideup.co.il/api

# הדומיין הבסיסי לזיהוי tenants (ב-frontend, לחילוץ slug מה-host).
# בפיתוח: localhost (ואז משתמשים ב-?tenant=foo כ-override).
# בפרודקשן: rideup.co.il
VITE_BASE_DOMAIN=localhost

# Google OAuth Client ID (אחרי שלב 2)
VITE_GOOGLE_CLIENT_ID=
