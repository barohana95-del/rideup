# =====================================================================
# RideUp Frontend — Environment Variables (template)
# Copy to `.env.local` (gitignored) and fill in real values.
# =====================================================================

# Backend API base URL.
# In dev: '/api' so Vite proxy forwards to Hostinger.
# In prod: same domain, '/api'.
VITE_API_URL=/api

# Base domain for tenant routing (still used by some legacy code, harmless).
VITE_BASE_DOMAIN=rideup.integrity-web.com

# Google OAuth Client ID (Web application). PUBLIC — safe in frontend.
# Get it from Google Cloud Console → Credentials.
VITE_GOOGLE_CLIENT_ID=
